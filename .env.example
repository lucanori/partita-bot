# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Admin Interface Configuration
ADMIN_PORT=5000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# Flask Secret Key (use a secure random string in production)
FLASK_SECRET_KEY=your_secure_random_string_here

# Debug Mode (true/false)
DEBUG=false

# Bot Timezone (used for all notifications)
TIMEZONE=Europe/Rome

# Exa Answer API Key (needed for event detection)
EXA_API_KEY=your_exa_api_key_here

# Bot Language for event search responses (e.g., English, Italian, Spanish)
BOT_LANGUAGE=English
